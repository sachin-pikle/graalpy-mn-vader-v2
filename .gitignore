# Maven / Micronaut build output
target/
out/
*.class

# Java IDEs
.idea/
*.iml
.classpath
.project
.settings/
.factorypath
.vscode/

# Editor temp files
*.swp
*.swo
*~

# JVM crash logs
hs_err_pid*
replay_pid*

# Local logs
*.log

# Embedded Python module cache files
__pycache__/
*.py[cod]

# macOS Finder metadata
.DS_Store

# Keep the wrapper bootstrap jar out of version control.
# ./mvnw will download it on first use.
.mvn/wrapper/maven-wrapper.jar

# Unlike the stock Java template, do not ignore *.jar or *.zip:
# this repo intentionally keeps demo artifacts under _success/.
